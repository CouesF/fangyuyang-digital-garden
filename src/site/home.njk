---
layout: layouts/home-layout.njk
permalink: /
---

{# ── Hero ─────────────────────────────────────────────────────────── #}
<section class="home-hero">
  {% if profile.avatar %}
    <img class="home-avatar" src="{{ profile.avatar }}" alt="{{ profile.name }}" onerror="this.style.display='none'">
  {% endif %}
  <div class="home-hero-text">
    <h1 class="home-hero-name">{{ profile.name }}</h1>
    <p class="home-hero-title">{{ profile.title }}</p>
    <p class="home-hero-bio">{{ profile.bio }}</p>
    <div class="home-hero-links">
      {% if profile.links.email %}
        <a href="mailto:{{ profile.links.email }}">Email</a>
      {% endif %}
      {% if profile.links.github %}
        <a href="{{ profile.links.github }}" target="_blank" rel="noopener">GitHub</a>
      {% endif %}
      {% if profile.links.scholar %}
        <a href="{{ profile.links.scholar }}" target="_blank" rel="noopener">Google Scholar</a>
      {% endif %}
      {% if profile.links.cv %}
        <a href="{{ profile.links.cv }}" target="_blank" rel="noopener">CV</a>
      {% endif %}
    </div>
    {% if profile.researchInterests.length %}
      <p class="home-interests">
        <span class="home-interests-label">Interests: </span>{{ profile.researchInterests | join(", ") }}
      </p>
    {% endif %}
  </div>
</section>

{# ── Updates / News ───────────────────────────────────────────────── #}
{%- set allUpdates = [] -%}
{% for u in updates %}
  {%- set allUpdates = (allUpdates.push({ title: u.title, date: u.date, content: u.content, note: u.note }), allUpdates) -%}
{% endfor %}
{% for note in collections.dailyUpdates %}
  {%- set allUpdates = (allUpdates.push({ title: note.data.title or note.fileSlug, date: note.date | isoDate | truncate(10, false, ''), content: note.data.description or "", note: note.url }), allUpdates) -%}
{% endfor %}

{% if allUpdates.length %}
<section class="home-section home-updates-section">
  <h2>News</h2>
  <ul class="home-updates-list">
    {% for u in allUpdates %}
      <li class="home-update-item">
        <span class="home-update-date">{{ u.date }}</span>
        <span class="home-update-title">
          {% if u.note %}
            <a href="{{ u.note }}">{{ u.title }}</a>
          {% else %}
            {{ u.title }}
          {% endif %}
        </span>
        {% if u.content %}
          <span class="home-update-content">— {{ u.content }}</span>
        {% endif %}
      </li>
    {% endfor %}
  </ul>
</section>
{% endif %}

{# ── Research & Projects ──────────────────────────────────────────── #}
{% if projects.length %}
<section class="home-section">
  <h2>Research &amp; Projects</h2>

  {# Featured projects — full card #}
  {% set featured = [] %}
  {% for p in projects %}{% if p.featured %}{% set featured = (featured.push(p), featured) %}{% endif %}{% endfor %}
  {% if featured.length %}
    <div class="home-projects-featured">
      {% for p in featured %}
        <div class="home-project-card{% if p.img %} home-project-card--has-img{% endif %}">
          <div class="home-project-body">
            <div class="home-project-meta">
              <span class="home-project-date">{{ p.date }}</span>
              {% for tag in p.tags %}
                <span class="home-project-tag">{{ tag }}</span>
              {% endfor %}
            </div>
            <h3 class="home-project-title">{{ p.title }}</h3>
            <p class="home-project-desc">{{ p.description }}</p>
            <div class="home-project-links">
              {% if p.links.paper %}<a href="{{ p.links.paper }}" target="_blank" rel="noopener">[Paper]</a>{% endif %}
              {% if p.links.code %}<a href="{{ p.links.code }}" target="_blank" rel="noopener">[Code]</a>{% endif %}
              {% if p.links.demo %}<a href="{{ p.links.demo }}" target="_blank" rel="noopener">[Demo]</a>{% endif %}
              {% if p.links.note %}<a href="{{ p.links.note }}">[Notes]</a>{% endif %}
            </div>
          </div>
          {% if p.img %}
            <img class="home-project-thumb" src="{{ p.img }}" alt="{{ p.title }}" loading="lazy" onerror="this.style.display='none'">
          {% endif %}
        </div>
      {% endfor %}
    </div>
  {% endif %}

  {# Other projects — compact list #}
  {% set others = [] %}
  {% for p in projects %}{% if not p.featured %}{% set others = (others.push(p), others) %}{% endif %}{% endfor %}
  {% if others.length %}
    <ul class="home-projects-list">
      {% for p in others %}
        <li class="home-project-item">
          <span class="home-project-date">{{ p.date }}</span>
          <span class="home-project-title-inline">
            {% if p.links.note %}
              <a href="{{ p.links.note }}">{{ p.title }}</a>
            {% elif p.links.paper %}
              <a href="{{ p.links.paper }}" target="_blank" rel="noopener">{{ p.title }}</a>
            {% else %}
              {{ p.title }}
            {% endif %}
          </span>
          {% for tag in p.tags %}
            <span class="home-project-tag">{{ tag }}</span>
          {% endfor %}
          {% if p.links.code %}<a class="home-project-link-sm" href="{{ p.links.code }}" target="_blank" rel="noopener">[Code]</a>{% endif %}
        </li>
      {% endfor %}
    </ul>
  {% endif %}
</section>
{% endif %}

{# ── Education ────────────────────────────────────────────────────── #}
{% if profile.education.length %}
<section class="home-section">
  <h2>Education</h2>
  <ul class="home-edu-list">
    {% for item in profile.education %}
      <li>
        <span class="home-edu-degree">{{ item.degree }}</span>
        <span class="home-edu-school">{{ item.school }}</span>
        <span class="home-edu-year">{{ item.year }}</span>
      </li>
    {% endfor %}
  </ul>
</section>
{% endif %}
